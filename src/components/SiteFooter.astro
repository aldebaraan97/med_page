---
import { client } from "../config/client";
const { practitioner, locations } = client;

// Explicitly marked, not string-matched. A clone that renames its credential
// label keeps working; a clone that marks none simply omits the segment
// rather than rendering "Cédula profesional  ·" with a hole in it.
const primary = practitioner.licenses.find((l) => l.primary);
const { city, state } = locations[0];
---
<footer
  class="mx-auto mt-12 max-w-wrap border-t border-rule px-5 pt-5 pb-6 text-fine text-muted"
>
  <p>
    {practitioner.name}
    {primary && <> · {primary.label} {primary.value}</>}
    {" "}· {practitioner.specialtyLabel} en {city}, {state}
  </p>
</footer>
