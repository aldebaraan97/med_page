---
import { client } from "../config/client";
const { practitioner, locations } = client;
const cedula = practitioner.licenses.find((l) => l.label.startsWith("Cédula profesional"));
const city = locations[0].city;
const state = locations[0].state;
---
<footer
  class="mx-auto mt-12 max-w-wrap border-t border-rule px-5 pt-5 pb-6 text-fine text-muted"
>
  <p>
    {practitioner.name} · Cédula profesional {cedula?.value} ·
    {practitioner.specialtyLabel} en {city}, {state}
  </p>
</footer>