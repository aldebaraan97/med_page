---
import { client } from "../config/client";
import WhatsAppCta from "./WhatsAppCta.astro";
import WhatsAppIcon from "./WhatsAppIcon.astro";
const { copy, hours } = client;
---
<header class="bg-brand pt-12 pb-10 text-paper">
  <div class="mx-auto max-w-wrap px-5">
    <p class="mb-3 text-fine uppercase tracking-[0.09em] text-brand-soft">
      {copy.eyebrow}
    </p>

    <h1
      class="mb-3 font-display text-[clamp(2rem,6vw,3rem)] font-semibold leading-[1.15] tracking-[-0.015em]"
    >
      {client.practitioner.name}
    </h1>

    <p class="mb-7 max-w-[34rem] text-lede text-brand-pale">{copy.lede}</p>

    <WhatsAppCta label={copy.ctaHero} context="hero">
      <WhatsAppIcon slot="icon" />
    </WhatsAppCta>

    <p class="mt-3.5 text-sm text-brand-soft">
      {copy.ctaSub} · {hours.display}
    </p>
  </div>
</header>