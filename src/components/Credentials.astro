---
// The signature element: a credential document that overlaps the hero field.
// The -mt-7 pull is the whole gesture — the card is "laid on" the page.
import { client } from "../config/client";
const { licenses, tenure } = client.practitioner;
---
<section id="credenciales" class="mx-auto max-w-wrap px-5">
  <div
    class="-mt-7 rounded-sm border-x border-b border-t-4 border-rule border-t-accent bg-white px-6 py-5 shadow-[0_1px_2px_rgb(26_43_34_/_0.06)]"
  >
    <p class="mb-3.5 text-micro font-semibold uppercase tracking-[0.14em] text-accent">
      Registro profesional
    </p>

    <dl class="grid gap-3 sm:grid-cols-3 sm:gap-5">
      {licenses.map((l) => (
        <div>
          <dt class="text-xs uppercase tracking-[0.06em] text-muted">{l.label}</dt>
          <dd
            class:list={[
              "mt-0.5",
              l.mono ? "font-mono text-datum tracking-[0.04em]" : "text-[0.975rem]",
            ]}
          >
            {l.value}
          </dd>
        </div>
      ))}
    </dl>

    <p class="mt-4 border-t border-rule pt-3.5 text-fine text-muted">{tenure}</p>
  </div>
</section>