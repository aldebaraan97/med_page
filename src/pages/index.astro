---
import '../styles/global.css';
const phoneDisplay = "55 6323 2833";
const phoneLink = "+525563232833";
const doctorName = "Dr. Vicente Lavielle";
const specialty = "Pediatra";
const location = "Cuautitlán Izcalli";
const yearsExperience = "30+";
const cedula = "1707043";
// WhatsApp is no longer a booking door — it's a low-weight questions channel.
// Two numbers: the doctor and the assistant. Both fire the existing
// whatsapp_click event (name unchanged) with a contact param to tell them apart.
const waDoctor = "525521068585";
const waAssistant = "525563232833";
const waQuestionMsg = encodeURIComponent("Tengo una duda");
const waDoctorLink = `https://wa.me/${waDoctor}?text=${waQuestionMsg}`;
const waAssistantLink = `https://wa.me/${waAssistant}?text=${waQuestionMsg}`;

// Cal.com inline booking embed.
// TODO: replace with the real public "Consulta pediátrica" event link once the
// Cal.com account/event type is created (format: "<username>/<event-slug>").
const calLink = "alde-01/cita-pediatrica";
// Match the embed to the page accent (Tailwind blue-600) so it reads as native.
const calBrandColor = "#2EA3D9";
// Mornings only — must match the Cal.com availability (dashboard).
const hoursDisplay = "lunes a sábado, 8:00 a 14:30";
---

<!DOCTYPE html>
<html lang="es">
  <head>
    <!-- Google Tag Manager -->
    <script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
    new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
    j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
    'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
    })(window,document,'script','dataLayer','GTM-TB2P8V8P');</script>
    <!-- End Google Tag Manager -->

    <meta charset="UTF-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={`${doctorName} - Pediatra en ${location} con más de ${yearsExperience} años de experiencia. Llama para agendar una cita.`} />
    <title>{doctorName} - Pediatra en {location}</title>

    <!-- Capture Google Ads attribution keys (gclid/gbraid/wbraid) on load.
         Stored for the offline-conversion upload (Phase 2) and attached to the
         Cal.com booking as metadata. Attribution key only — never any PII. -->
    <script is:inline>
      (function () {
        try {
          var params = new URLSearchParams(window.location.search);
          ['gclid', 'gbraid', 'wbraid'].forEach(function (k) {
            var v = params.get(k);
            if (v) sessionStorage.setItem('lav_' + k, v);
          });
        } catch (e) {}
        window.getAdAttribution = function () {
          var read = function (k) {
            try { return sessionStorage.getItem('lav_' + k) || ''; } catch (e) { return ''; }
          };
          return { gclid: read('gclid'), gbraid: read('gbraid'), wbraid: read('wbraid') };
        };
      })();
    </script>
  </head>

  <body class="bg-slate-50 text-slate-900 antialiased">
    <!-- Google Tag Manager (noscript) -->
    <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-TB2P8V8P"
    height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
    <!-- End Google Tag Manager (noscript) -->

    <main class="min-h-screen flex items-center justify-center px-4 py-12">
      <div class="max-w-xl w-full bg-white rounded-2xl shadow-sm border border-slate-200 p-8 md:p-12">
        
        <div class="text-center">
          <p class="text-sm uppercase tracking-wider text-blue-600 font-semibold mb-2">
            {specialty} en {location}
          </p>
          <h1 class="text-3xl md:text-4xl font-bold text-slate-900 mb-3">
		        {doctorName} Sotomayor
          </h1>
          <p class="text-lg text-slate-600 mb-6">
            Más de {yearsExperience} años cuidando la salud de tus hijos
          </p>
        </div>

        <div class="flex flex-wrap justify-center gap-x-4 gap-y-2 text-sm text-slate-500 mb-8 pb-8 border-b border-slate-200">
          <span>Cédula profesional {cedula}</span>
          <span aria-hidden="true">·</span>
          <span>Egresado de la UNAM</span>
          <span aria-hidden="true">·</span>
          <span>20+ opiniones verificadas</span>
        </div>

        <!-- Primary CTA: Cal.com inline booking widget. Patient picks an open
             morning slot and it locks instantly (no host confirmation, no
             verification). On completion Cal.com redirects to /cita-confirmada
             (configured in the Cal.com dashboard), where the conversion fires. -->
        <section class="text-center mb-8">
          <p class="text-slate-900 font-semibold text-lg mb-1">
            Agenda tu cita en línea
          </p>
          <p class="text-sm text-slate-500 mb-1">
            Elige el horario que más te convenga. Confirmación inmediata.
          </p>
          <p class="text-sm text-slate-500 mb-4">
            Horario de atención: lunes a sábado, 8:00 a 17:00
          </p>
          <div
            id="cal-booking"
            class="w-full min-h-[600px] rounded-xl border border-slate-200 overflow-hidden bg-white"
          ></div>
        </section>

        <!-- WhatsApp demoted to a low-weight questions channel (no longer a
             booking door). Two numbers — doctor + assistant — rendered as small
             icons, not buttons. Each pushes the existing whatsapp_click event
             (name unchanged) with a contact param so taps per number are observable. -->
        <div class="text-center mb-8">
          <p class="text-sm text-slate-500 mb-3">¿Dudas? Escríbenos por WhatsApp</p>
          <div class="flex justify-center gap-6">
            <a
              href={waDoctorLink}
              onclick="dataLayer && dataLayer.push({event: 'whatsapp_click', contact: 'doctor'});"
              target="_blank"
              rel="noopener"
              aria-label="Escríbele al consultorio del Dr. Lavielle por WhatsApp"
              class="inline-flex items-center gap-1.5 text-sm text-slate-500 hover:text-green-700 transition-colors"
            >
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
              </svg>
              Consultorio
            </a>
            <a
              href={waAssistantLink}
              onclick="dataLayer && dataLayer.push({event: 'whatsapp_click', contact: 'assistant'});"
              target="_blank"
              rel="noopener"
              aria-label="Escríbele a la asistente por WhatsApp"
              class="inline-flex items-center gap-1.5 text-sm text-slate-500 hover:text-green-700 transition-colors"
            >
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
              </svg>
              Asistente
            </a>
          </div>
        </div>

        <div class="text-slate-700 leading-relaxed">
          <p class="mb-3">
            Con más de tres décadas de experiencia clínica, el Dr. Lavielle ofrece
            atención pediátrica integral desde el nacimiento hasta la adolescencia.
          </p>
          <p>
            Consultas en Hospital San Rafael {location}.
            Se aceptan GNP Seguros, MetLife y Seguros Monterrey.
          </p>
        </div>

        <!-- Doctoralia booking button removed: it was an untracked off-site exit
             that bypassed the owned booking/conversion flow. Only the verified-
             reviews social proof is kept (plain text, no booking link). -->
        <div class="text-center mt-8 pt-8 border-t border-slate-200">
          <p class="text-sm text-slate-500">
            ⭐ 20+ opiniones verificadas en Doctoralia
          </p>
        </div>

      </div>
    </main>

    <!-- Cal.com inline embed loader + init. Threads the captured Google Ads
         attribution keys into the booking as metadata (config "metadata[key]"
         syntax) so they ride along for the Phase-2 offline-conversion upload. -->
    <script is:inline define:vars={{ calLink, calBrandColor }}>
      (function (C, A, L) {
        let p = function (a, ar) { a.q.push(ar); };
        let d = C.document;
        C.Cal = C.Cal || function () {
          let cal = C.Cal;
          let ar = arguments;
          if (!cal.loaded) {
            cal.ns = {};
            cal.q = cal.q || [];
            d.head.appendChild(d.createElement("script")).src = A;
            cal.loaded = true;
          }
          if (ar[0] === L) {
            const api = function () { p(api, arguments); };
            const namespace = ar[1];
            api.q = api.q || [];
            if (typeof namespace === "string") {
              cal.ns[namespace] = cal.ns[namespace] || api;
              p(cal.ns[namespace], ar);
              p(cal, ["initNamespace", namespace]);
            } else {
              p(cal, ar);
            }
            return;
          }
          p(cal, ar);
        };
      })(window, "https://app.cal.com/embed/embed.js", "init");

      var attribution = (window.getAdAttribution && window.getAdAttribution()) || {};
      var bookingConfig = { layout: "month_view" };
      if (attribution.gclid) bookingConfig["metadata[gclid]"] = attribution.gclid;
      if (attribution.gbraid) bookingConfig["metadata[gbraid]"] = attribution.gbraid;
      if (attribution.wbraid) bookingConfig["metadata[wbraid]"] = attribution.wbraid;

      Cal("init", { origin: "https://cal.com" });
      Cal("inline", {
        elementOrSelector: "#cal-booking",
        calLink: calLink,
        config: bookingConfig
      });
      Cal("ui", {
        hideEventTypeDetails: false,
        layout: "month_view",
        cssVarsPerTheme: { light: { "cal-brand": calBrandColor } }
      });
    </script>
  </body>
</html>