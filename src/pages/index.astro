---
// The page is an assembly order, nothing else.
// Every literal lives in src/config/client.ts; every rule lives in @theme.
//
// booking.mode swaps the contact channel. Both modes fill the same calendar,
// so the n8n reminder flow downstream is identical either way.
import { client } from "../config/client";
import Base from "../layouts/Base.astro";
import Hero from "../components/Hero.astro";
import Credentials from "../components/Credentials.astro";
import Booking from "../components/Booking.astro";
import Services from "../components/Services.astro";
import Pricing from "../components/Pricing.astro";
import Locations from "../components/Locations.astro";
import Questions from "../components/Questions.astro";
import SiteFooter from "../components/SiteFooter.astro";
import Dock from "../components/Dock.astro";

const selfServe = client.booking.mode === "self-serve";
---

<Base>
  <Hero />
  <Credentials />

  {/* Self-serve: the embed is the primary CTA, sitting directly under the
      credential card, and WhatsApp demotes to a questions link near the end.
      WhatsApp mode: neither renders; the hero + dock pills are the whole CTA. */}
  {selfServe && <Booking />}

  <Services />
  <Pricing />
  <Locations />

  {selfServe && <Questions />}

  <SiteFooter />
  <Dock />
</Base>
